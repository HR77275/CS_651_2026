# Pascal VOC data
/data/
/data/VOCtrainval_11-May-2012.tar
/data/VOCdevkit/

# Training outputs and checkpoints
/outputs/
*.pt
*.pth

# Python cache
__pycache__/
*.py[cod]

# Local environment files
.venv/
venv/
.env

# 3DHGS integration
# Keep the upstream 3DHGS checkout local and commit only our optimizer-tracking changes.
/3DHGS/*
!/3DHGS/arguments/
/3DHGS/arguments/*
!/3DHGS/arguments/__init__.py
!/3DHGS/scene/
/3DHGS/scene/*
!/3DHGS/scene/gaussian_model.py
!/3DHGS/train.py

# 3DHGS local datasets, outputs, caches, and compiled artifacts
/3DHGS/.git/
/3DHGS/.git_backup/
/3DHGS/assets/
/3DHGS/images/
/3DHGS/data/
/3DHGS/outputs/
/3DHGS/output/
/3DHGS/**/__pycache__/
/3DHGS/**/*.py[cod]
/3DHGS/nohup.out
/3DHGS/*.log
/3DHGS/**/*.egg-info/
/3DHGS/**/build/
/3DHGS/**/*.so
/3DHGS/**/*.pyd
/3DHGS/**/*.dll
/3DHGS/**/*.lib
/3DHGS/**/*.pdb
/3DHGS/**/*.o
/3DHGS/**/*.ninja
/3DHGS/**/.ninja_deps
/3DHGS/**/.ninja_log

# 3DHGS heavy model artifacts if copied outside ignored outputs
/3DHGS/**/*.ply
/3DHGS/**/*.pth
/3DHGS/**/*.pt
/3DHGS/**/*.npy
/3DHGS/**/*.npz
